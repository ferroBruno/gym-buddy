{
  "version": 1,
  "defaultEffect": "allow",
  "rules": [
    {
      "id": "block-secrets",
      "effect": "deny",
      "when": {
        "paths": [
          "**/.env*",
          "**/*.pem",
          "**/*.key",
          "**/*secret*"
        ]
      },
      "reason": "Secret-like files are blocked by policy."
    }
  ]
}
