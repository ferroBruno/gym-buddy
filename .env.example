GENERIC_TIMEZONE=America/Sao_Paulo

# n8n local runtime
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-at-least-32-characters

# n8n database
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# Telegram Bot API
# Create the bot with BotFather and keep the token only in .env or n8n credentials.
TELEGRAM_BOT_TOKEN=change-me

# Future AI agent integration boundary.
# The core training agent can later live behind an HTTP endpoint called by n8n.
AI_AGENT_WEBHOOK_URL=http://host.docker.internal:3000/session/message
AI_AGENT_API_TOKEN=change-me
