# n8n
N8N_VERSION=2.10.2
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_SECURE_COOKIE=false

# Database
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-this-local-password
POSTGRES_DB=n8n

# Required: generate and keep stable
# This key encrypts n8n credentials. Do not lose it after creating credentials.
N8N_ENCRYPTION_KEY=generate-a-random-32-plus-character-key

# Future credentials should be configured inside n8n credentials when possible.
# Do not commit real tokens or API keys.
# TELEGRAM_BOT_TOKEN=
# OPENAI_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional local LLM provider
# Start with: docker compose --profile llm up -d ollama
# Then pull a model, for example: docker compose exec ollama ollama pull llama3.2:3b
OLLAMA_VERSION=latest
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
